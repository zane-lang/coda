name myproject
type executable

# hello
compiler {
	debug "hi h"
	optimize true
}
compiler 3

deps [
	key link version
	http github.com/zane-lang/http 2.1.0
	plot github.com/zane-lang/plot 4.0.3
]

meta {
	author "The Lazy Cat"
	description "a test project"
}

targets [
	x86_64-linux
	x86_64-windows
	aarch64-macos
]
