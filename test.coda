name myproject
type executable

test "hello\nworld"

# this is a comment
# this is another line
compiler {
	debug true
	optimize true
}

deps [
	key link version
	"ht tp" github.com/zane-lang/http 2.1.0
	plot github.com/zane-lang/plot 4.0.3
]

meta {
	author "The Lazy Cat"
	description "a test project"
}

targets [
	x86_64-linux
	x86_64-windows
	aarch64-macos
]
