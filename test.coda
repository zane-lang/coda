name myproject
type executable

test "hello\nworld"

# hello
# bye is a red fox
# hi hello
"compiler" {
	ö ba
	debug "hi h"
	optimize true
}

deps [
	key link version
	"ht tp" github.com/zane-lang/http 2.1.0
	plot github.com/zane-lang/plot 4.0.3
]

meta {
	author "The Lazy Cat"
	description "a test project"
}

targets [
	x86_64-linux
	x86_64-windows
	aarch64-macos
]
