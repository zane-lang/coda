name myproject
type executable

deps [
    key link version
    plot github.com/zane-lang/plot 4.0.3
    http github.com/zane-lang/http 2.1.0
]

compiler {
    debug false
    optimize true
}

targets [
    x86_64-linux
    x86_64-windows
    aarch64-macos
]

meta {
    author "The Lazy Cat"
    description "a test project"
}
